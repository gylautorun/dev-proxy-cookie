{
  "name": "dev-proxy-cookie",
  "version": "1.0.0",
  "description": "开发环境代理Cookie注入工具，支持文件监听自动重载和自动代理",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "dev",
    "proxy",
    "cookie",
    "vite",
    "vue",
    "webpack",
    "auto-proxy",
    "hot-reload",
    "cookie-injection"
  ],
  "author": "gyl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git@github.com:gylautorun/dev-proxy-cookie.git"
  },
  "bugs": {
    "url": "https://github.com/gylautorun/dev-proxy-cookie/issues"
  },
  "homepage": "https://github.com/gylautorun/dev-proxy-cookie/blob/main/README.md",
  "dependencies": {
    "chokidar": "^3.5.3",
    "http-proxy": "^1.18.1"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.14",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vite": "^4.5.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
