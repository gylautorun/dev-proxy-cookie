# npm config set registry https://registry.npmmirror.com/ # 设置npm源为淘宝镜像
# ============================================================
# dev-proxy-cookie npm 配置文件
# ============================================================
# 此文件用于配置 npm 行为，包括注册表地址、认证信息等

# ------------------------------
# 注册表配置
# ------------------------------
# 设置 npm 源为淘宝镜像（国内用户推荐使用）
# npm config set registry https://registry.npmmirror.com/

# 官方 npm 注册表（发布包时必须使用官方源）
registry=https://registry.npmjs.org/

# ------------------------------
# npm 认证配置
# ------------------------------
# 以下配置用于 npm 发布认证，有三种方式：
# 
# 方式一：使用环境变量（推荐，不提交到版本控制）
# 在终端执行：export NPM_TOKEN=your_token_here
# 或在 ~/.bashrc 或 ~/.zshrc 中添加：export NPM_TOKEN=your_token_here
# 
# 方式二：使用 authToken（适合 CI/CD 环境）
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}
# 
# 方式三：使用用户名和密码（不推荐，不安全）
# //registry.npmjs.org/:username=your_username
# //registry.npmjs.org/:_password=your_base64_encoded_password
# 
# 获取 npm token 的方法：
# 1. 登录 https://www.npmjs.com/
# 2. 进入个人设置页面（Profile Settings）
# 3. 点击 "Access Tokens"
# 4. 点击 "Generate New Token"
# 5. 选择 token 类型：Publish（发布权限）或 Automation（CI/CD 自动化）

# ------------------------------
# 发布配置
# ------------------------------
# 强制使用 npm 官方源发布（防止发布到其他镜像）
# publishConfig.registry=https://registry.npmjs.org/

# ------------------------------
# 发布命令使用场景
# ------------------------------
# 以下是项目支持的发布命令及其使用场景：
# 
# 【正式版本发布】
# npm run publish:patch    # 修复 bug，升级补丁版本 (1.0.0 → 1.0.1)
# npm run publish:minor    # 添加新功能，升级次版本 (1.0.0 → 1.1.0)
# npm run publish:major    # 重大变更，升级主版本 (1.0.0 → 2.0.0)
# 
# 【预发布版本发布】
# npm run publish:beta     # 发布 Beta 测试版 (1.0.0 → 1.0.1-beta.1)
# npm run publish:alpha    # 发布 Alpha 测试版 (1.0.0 → 1.0.1-alpha.1)
# 
# 【版本升级（不发布）】
# npm run bump:patch       # 仅升级补丁版本
# npm run bump:minor       # 仅升级次版本
# npm run bump:major       # 仅升级主版本
# npm run bump:beta        # 仅升级 Beta 版本
# npm run bump:alpha       # 仅升级 Alpha 版本
# npm run bump:major-beta  # 升级主版本并添加 Beta 标记
# npm run bump:minor-beta  # 升级次版本并添加 Beta 标记
# npm run bump:major-alpha # 升级主版本并添加 Alpha 标记
# npm run bump:minor-alpha # 升级次版本并添加 Alpha 标记
# 
# 【交互式发布脚本】
# bash scripts/publish.sh  # 完整的交互式发布流程
# 
# ------------------------------
# 安装命令示例
# ------------------------------
# npm install dev-proxy-cookie          # 安装最新正式版本
# npm install dev-proxy-cookie@beta     # 安装最新 Beta 版本
# npm install dev-proxy-cookie@alpha    # 安装最新 Alpha 版本
# npm install dev-proxy-cookie@1.0.0    # 安装指定版本
# 
# ------------------------------
# 注意事项
# ------------------------------
# 1. 发布前请确保已登录 npm（npm login）或配置了正确的 token
# 2. 正式发布前建议先发布到测试环境进行验证
# 3. 预发布版本不会影响 latest tag，用户需要显式指定版本安装
# 4. 发布后会自动创建 git tag 并推送到远程仓库
